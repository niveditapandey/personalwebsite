---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Nivedita Pandey">
  <div class="home">
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text-block">
          <h1 class="hero-title">
            Applied AI, Digital Innovation, and Strategic Growth Leader
          </h1>
          <p class="hero-text">
            16 years at the intersection of AI, capital, and institutions — across the US, UK, Singapore, and India.
          </p>
          <div class="hero-links">
            <a href="/about" class="hero-link">Bio →</a>
            <a href="/projects" class="hero-link">Past Work →</a>
            <a href="/problems" class="hero-link">Problems I'm Working On →</a>
          </div>
        </div>
        <div class="hero-photo-block">
          <img
            src="/images/hero-professional.png"
            alt="Nivedita Pandey"
            class="hero-photo"
          />
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
  }

  .hero {
    padding: 2rem 0 3rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }

  .hero-photo-block {
    flex-shrink: 0;
  }

  .hero-photo {
    width: 280px;
    height: auto;
    display: block;
    border: 1px solid var(--border);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
  }

  .hero-title {
    font-size: 2.25rem;
    line-height: 1.25;
    margin-bottom: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .hero-text {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    max-width: 750px;
  }

  .hero-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  .hero-link {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--accent);
    transition: color 0.2s ease;
  }

  .hero-link:hover {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-photo-block {
      order: -1;
    }

    .hero-photo {
      width: 160px;
      margin: 0 auto;
    }

    .hero-title {
      font-size: 1.75rem;
    }
  }
</style>
