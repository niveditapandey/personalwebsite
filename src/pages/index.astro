---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout title="Nivedita Pandey">
  <div class="home">
    <section class="hero">
      <div class="hero-banner">
        <img
          src="/images/hero-professional.png"
          alt="Nivedita Pandey"
          class="hero-banner-img"
        />
      </div>
      <h1 class="hero-title">
        Applied AI, Digital Innovation, and Strategic Growth Leader
      </h1>
      <p class="hero-text">
        16 years at the intersection of AI, capital, and institutions — across the US, UK, Singapore, and India.
      </p>
      <div class="hero-links">
        <a href="/about" class="hero-link">Bio →</a>
        <a href="/projects" class="hero-link">Past Work →</a>
        <a href="/problems" class="hero-link">Problems I'm Working On →</a>
      </div>
      <div class="stat-bar">
        <div class="stat"><span class="stat-number">$130M+</span><span class="stat-label">B2B revenue built from zero</span></div>
        <div class="stat"><span class="stat-number">268%</span><span class="stat-label">YoY portfolio revenue growth</span></div>
        <div class="stat"><span class="stat-number">$124M</span><span class="stat-label">B2C GMV</span></div>
        <div class="stat"><span class="stat-number">210</span><span class="stat-label">Civil servants trained on AI</span></div>
        <div class="stat"><span class="stat-number">15+</span><span class="stat-label">Multi-million dollar deals</span></div>
        <div class="stat"><span class="stat-number">50%+</span><span class="stat-label">Deal conversion lift</span></div>
        <div class="stat"><span class="stat-number">10M+</span><span class="stat-label">Customers acquired</span></div>
        <div class="stat"><span class="stat-number">42</span><span class="stat-label">AI prototypes with government</span></div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
  }

  .hero {
    padding-bottom: 3rem;
  }

  .hero-banner {
    width: 100%;
    height: 380px;
    overflow: hidden;
    margin-bottom: 2.5rem;
  }

  .hero-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .hero-title {
    font-size: 2.25rem;
    line-height: 1.25;
    margin-bottom: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    max-width: 700px;
  }

  .hero-text {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    max-width: 650px;
  }

  .hero-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  .hero-link {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--accent);
    transition: color 0.2s ease;
  }

  .hero-link:hover {
    color: var(--text-primary);
  }

  .stat-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 2rem 0;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.15);
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }
  .stat { display: flex; flex-direction: column; gap: 4px; }
  .stat-number { font-size: 1.4rem; font-weight: 600; }
  .stat-label { font-size: 0.75rem; opacity: 0.7; line-height: 1.4; }
  @media (max-width: 600px) {
    .stat-bar { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero-banner {
      height: 220px;
    }

    .hero-title {
      font-size: 1.75rem;
    }
  }
</style>
