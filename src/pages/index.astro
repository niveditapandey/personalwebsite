---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout title="Nivedita Pandey">
  <div class="home">
    <section class="hero">
      <div class="hero-banner">
        <img
          src="/images/hero-professional.png"
          alt="Nivedita Pandey"
          class="hero-banner-img"
        />
      </div>
      <h1 class="hero-title">
        Applied AI, Digital Innovation, and Strategic Growth Leader
      </h1>
      <p class="hero-text">
        16 years at the intersection of AI, capital, and institutions — across the US, UK, Singapore, and India.
      </p>
      <div class="hero-links">
        <a href="/about" class="hero-link">Bio →</a>
        <a href="/projects" class="hero-link">Past Work →</a>
        <a href="/problems" class="hero-link">Problems I'm Working On →</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
  }

  .hero {
    padding-bottom: 3rem;
  }

  .hero-banner {
    width: 100%;
    height: 380px;
    overflow: hidden;
    margin-bottom: 2.5rem;
  }

  .hero-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
  }

  .hero-title {
    font-size: 2.25rem;
    line-height: 1.25;
    margin-bottom: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    max-width: 700px;
  }

  .hero-text {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    max-width: 650px;
  }

  .hero-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.75rem;
  }

  .hero-link {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--accent);
    transition: color 0.2s ease;
  }

  .hero-link:hover {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .hero-banner {
      height: 220px;
    }

    .hero-title {
      font-size: 1.75rem;
    }
  }
</style>
