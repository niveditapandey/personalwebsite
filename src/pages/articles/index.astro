---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Get all unique tags
const allTags = [...new Set(articles.flatMap(article => article.data.tags))];
---

<BaseLayout title="Articles — Nivedita Pandey">
  <div class="articles-page">
    <header class="page-header">
      <h1>Articles</h1>
      <p class="page-description">
        Long-form writing on technology, institutions, and systems.
      </p>
    </header>
    
    {allTags.length > 0 && (
      <div class="tags-filter">
        {allTags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
    
    <div class="articles-list">
      {articles.map((article) => (
        <article class="article-card">
          <a href={`/articles/${article.slug}`}>
            <time datetime={article.data.publishDate.toISOString()}>
              {article.data.publishDate.toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
              })}
            </time>
            <h2>{article.data.title}</h2>
            <p class="article-description">{article.data.description}</p>
            <div class="article-tags">
              {article.data.tags.map(tag => (
                <span class="tag-small">{tag}</span>
              ))}
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .articles-page {
    max-width: 900px;
  }
  
  .page-header {
    margin-bottom: 3rem;
  }
  
  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }
  
  .page-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
  }
  
  .tags-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  
  .tag {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  
  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  
  .article-card {
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }
  
  .article-card:last-child {
    border-bottom: none;
  }
  
  .article-card a {
    display: block;
    color: inherit;
  }
  
  .article-card time {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }
  
  .article-card h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-weight: 500;
    transition: color 0.2s ease;
  }
  
  .article-card:hover h2 {
    color: var(--accent);
  }
  
  .article-description {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .tag-small {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: rgba(125, 166, 255, 0.1);
    color: var(--accent);
    border-radius: 3px;
  }
  
  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }
  }
</style>
