---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout title="Contact — Nivedita Pandey">
  <div class="contact-page">
    <h1>Contact</h1>

    <div class="page-banner">
      <img
        src="/images/contact-fintech.png"
        alt="Nivedita Pandey at Singapore Fintech Festival"
        class="page-banner-img"
      />
      <p class="photo-caption">Singapore Fintech Festival, 2024</p>
    </div>

    <div class="contact-rows">
      <div class="contact-row">
        <span class="contact-label">General</span>
        <a href="mailto:np@niveditapandey.com" class="contact-link">np@niveditapandey.com</a>
      </div>
      <div class="contact-row">
        <span class="contact-label">Professional Engagements & Speaking</span>
        <a href="mailto:nivedita@dendrons.ai" class="contact-link">nivedita@dendrons.ai</a>
      </div>
    </div>

    <div class="social-row">
      <a href="https://www.linkedin.com/in/niveditapandey/" target="_blank" rel="noopener noreferrer" class="social-link">LinkedIn ↗</a>
      <span class="divider">·</span>
      <a href="https://twitter.com/niveditapandey" target="_blank" rel="noopener noreferrer" class="social-link">Twitter ↗</a>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 700px;
  }

  .contact-page h1 {
    font-size: 2.5rem;
    font-weight: 500;
    margin-bottom: 2rem;
  }

  .page-banner {
    width: 100%;
    max-height: 420px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .page-banner-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .photo-caption {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    margin-bottom: 3rem;
  }

  .contact-rows {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .contact-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .contact-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .contact-link {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--accent);
    transition: color 0.2s ease;
  }

  .contact-link:hover {
    color: var(--text-primary);
  }

  .social-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .social-link {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .social-link:hover {
    color: var(--accent);
  }

  .divider {
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .contact-page h1 {
      font-size: 2rem;
    }

    .page-banner {
      height: 220px;
    }
  }
</style>
