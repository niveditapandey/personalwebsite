---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Images — Nivedita Pandey">
  <div class="media-page">
    <header class="page-header">
      <h1>Images</h1>
      <p class="page-description">
        Photo gallery from events, travels, and beyond work interests.
      </p>
    </header>
    
    <div class="coming-soon">
      <p>Content coming soon.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .media-page {
    max-width: 900px;
  }
  
  .page-header {
    margin-bottom: 3rem;
  }
  
  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }
  
  .page-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
  }
  
  .coming-soon {
    text-align: center;
    padding: 4rem 0;
  }
  
  .coming-soon p {
    font-family: var(--font-heading);
    color: var(--text-muted);
    font-size: 1.125rem;
  }
</style>
