---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Media — Nivedita Pandey">
  <div class="media-page">
    <header class="page-header">
      <h1>Media</h1>
      <p class="page-description">
        Talks, interviews, presentations, and images.
      </p>
    </header>

    <section class="media-section">
      <h2 class="section-title">Videos</h2>
      <p class="section-description">
        Talks, interviews, and presentations on AI governance, digital infrastructure, and technology adoption.
      </p>
      <div class="coming-soon">
        <p>Content coming soon.</p>
      </div>
    </section>

    <section class="media-section">
      <h2 class="section-title">Images</h2>
      <p class="section-description">
        Photography and visual documentation.
      </p>
      <div class="coming-soon">
        <p>Content coming soon.</p>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .media-page {
    max-width: 900px;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .media-section {
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--border);
  }

  .media-section:last-child {
    border-bottom: none;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
    font-family: var(--font-heading);
    color: var(--text-primary);
  }

  .section-description {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .coming-soon {
    padding: 3rem 0;
  }

  .coming-soon p {
    font-family: var(--font-heading);
    color: var(--text-muted);
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }
  }
</style>
