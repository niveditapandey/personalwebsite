---
import BaseLayout from '../../layouts/BaseLayout.astro';

type Photo = { src: string; caption: string; position?: string; tall?: boolean; contain?: boolean };
type SubSection = { label: string; photos: Photo[] };

const skipaSections: SubSection[] = [
  {
    label: "Applied AI and Digital Innovation in Governance",
    photos: [
      { src: "/media/SKIPA-Lecture_AIGovernance-Jharkhand_Mar17.jpeg", caption: "AI Governance, Jan 2026" },
      { src: "/media/SKIPA-Lecture_GenAI-Slide_Feb27.jpg", caption: "GenAI lecture, Feb 2026" },
      { src: "/media/SKIPA-Lecture_AlgorithmicBias_Feb24.jpg", caption: "Algorithmic Bias, Feb 2026" },
      { src: "/media/SKIPA-Lecture_AIToolsInAction_Feb27.jpg", caption: "AI Tools in Action, Feb 2026", contain: true },
      { src: "/media/SKIPA-Lecture_AudienceView_Mar05.jpg", caption: "AI in War (1)" },
      { src: "/media/SKIPA-Lecture_HandRaised_Mar05.jpg", caption: "AI in War (2)", contain: true },
      { src: "/media/SKIPA-Lecture_PolicyToPrototype_Mar07.jpeg", caption: "Policy to Prototype, Mar 2026", contain: true },
      { src: "/media/SKIPA-Lecture_QRCode_Mar07.jpeg", caption: "Closing session of Applied AI lectures" },
    ]
  },
  {
    label: "Valedictory Ceremony",
    photos: [
      { src: "/media/SKIPA-Convocation_LampLighting.JPG", caption: "Lamp lighting" },
      { src: "/media/SKIPA-Convocation_PlantGift.JPG", caption: "Felicitation" },
      { src: "/media/SKIPA-Convocation_ValedictorySpeech.JPG", caption: "Valedictory speech" },
      { src: "/media/SKIPA-Convocation_CertificateHandover.JPG", caption: "Certificate distribution" },
    ]
  },
];
---

<BaseLayout title="Media - Nivedita Pandey">
  <div class="media-page">
    <header class="page-header">
      <h1>Media</h1>
      <p class="page-description">
        Interviews, webinars, panels, and public appearances.
      </p>
    </header>

    <!-- TV & Video -->
    <section class="media-section">
      <h2 class="section-title">TV &amp; Video</h2>
      <div class="video-grid">

        <div class="video-item">
          <div class="video-embed">
            <iframe
              src="https://www.youtube.com/embed/Kw0LkPl5Dco"
              title="AI Readiness: Why 75% of AI Projects Fail and How to Get It Right"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
          <div class="video-meta">
            <p class="video-title">AI Readiness: Why 75% of AI Projects Fail and How to Get It Right</p>
            <p class="video-host">Squirro · Webinar · Feb 2025</p>
            <p class="video-outlet-desc">Swiss enterprise GenAI platform specialising in knowledge intelligence and insight engines</p>
            <p class="video-description">On AI adoption failure modes, organisational readiness, and what separates AI initiatives that succeed from those that stall - drawing on experience across government, financial services, and enterprise.</p>
          </div>
        </div>

        <div class="video-item video-item--placeholder">
          <div class="video-embed video-embed--placeholder">
            <span class="placeholder-label">Link coming soon</span>
          </div>
          <div class="video-meta">
            <p class="video-title">AI and Its Impact on Us: How We Live, Work, and Prepare</p>
            <p class="video-host">Doordarshan · Interview · Apr 2026</p>
            <p class="video-description">A conversation on how AI will change the way we live and work - and what it will take for policymakers and the state to be ready for it.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- Radio & Audio -->
    <section class="media-section">
      <h2 class="section-title">Radio &amp; Audio</h2>
      <div class="video-grid">

        <div class="video-item video-item--placeholder">
          <div class="video-embed video-embed--placeholder">
            <span class="placeholder-label">Link coming soon</span>
          </div>
          <div class="video-meta">
            <p class="video-title">AI and Its Impact on Us</p>
            <p class="video-host">Radio 92.4 FM · Interview · Apr 2026</p>
            <p class="video-description">A wide-ranging conversation covering AI's practical applications, personal reflections on a career at the intersection of technology and institutions, and what the AI moment means for ordinary people.</p>
          </div>
        </div>

      </div>
    </section>

    <!-- Events & Talks -->
    <section class="media-section">
      <h2 class="section-title">Events &amp; Talks</h2>

      <div class="event-block">
        <div class="event-header">
          <span class="event-name">IIM Ranchi - Startup Conclave</span>
          <span class="event-meta">Feb 2026 · Invited as distinguished guest · Panelist and Judge</span>
        </div>
        <div class="ribbon-wrapper">
          <div class="ribbon-track">
            {[...Array(2)].flatMap(() => [
              { src: "/media/IIM_PanelDiscussion.JPG", caption: "Panel discussion 1" },
              { src: "/media/IIM_StartupConclave-Speaking.JPG", caption: "Panel discussion 2" },
              { src: "/media/IIM_StartupConclave-PanelDiscussion.jpeg", caption: "MSME-Startup Collaboration" },
              { src: "/media/IIM_AwardPlaque.JPG", caption: "Felicitated as judge & guest speaker" },
            ]).map((p) => (
              <figure class="photo-item">
                <img src={p.src} alt={p.caption} loading="lazy" />
                <figcaption>{p.caption}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </div>

      <div class="event-block">
        <div class="event-header">
          <span class="event-name">SKIPA</span>
          <span class="event-meta">Jan-Mar 2026</span>
        </div>
        {skipaSections.map((sub) => (
          <div class="event-subsection">
            <p class="subsection-label">{sub.label}</p>
            <div class="ribbon-wrapper">
              <div class="ribbon-track">
                {[...sub.photos, ...sub.photos].map((p) => (
                  <figure class={`photo-item${p.contain ? ' photo-item--contain' : ''}`}>
                    <img src={p.src} alt={p.caption} loading="lazy" style={p.position ? `object-position: ${p.position}` : undefined} />
                    <figcaption>{p.caption}</figcaption>
                  </figure>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

    </section>

  </div>
</BaseLayout>

<style>
  .media-page {
    max-width: 100%;
  }

  .page-header {
    max-width: 1000px;
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .media-section {
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--border);
  }

  .media-section:last-child {
    border-bottom: none;
  }

  .section-title {
    max-width: 1000px;
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 1.75rem;
    font-family: var(--font-heading);
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  /* Video / Audio cards */
  .video-grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 760px;
  }

  .video-item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .video-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: rgba(255,255,255,0.04);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .video-embed--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed rgba(255,255,255,0.15);
  }

  .placeholder-label {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .video-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.5;
    margin: 0;
  }

  .video-host {
    font-size: 0.8rem;
    font-family: var(--font-heading);
    color: var(--text-muted);
    letter-spacing: 0.03em;
    margin: 0;
  }

  .video-outlet-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 0;
    line-height: 1.5;
  }

  .video-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  /* Events & Talks */
  .event-block {
    margin-bottom: 3rem;
  }

  .event-block:last-child {
    margin-bottom: 0;
  }

  .event-header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.25rem;
  }

  .event-name {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .event-meta {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: var(--font-heading);
    letter-spacing: 0.02em;
  }

  .event-subsection {
    margin-bottom: 2rem;
  }

  .event-subsection:last-child {
    margin-bottom: 0;
  }

  .subsection-label {
    font-size: 0.8rem;
    font-family: var(--font-heading);
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  /* Ribbon */
  .ribbon-wrapper {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
  }

  .ribbon-track {
    display: flex;
    gap: 1rem;
    width: max-content;
    animation: ribbon-scroll 30s linear infinite;
  }

  .ribbon-track:hover {
    animation-play-state: paused;
  }

  @keyframes ribbon-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .photo-item {
    flex: 0 0 auto;
    width: 280px;
    margin: 0;
  }

  .photo-item img {
    width: 100%;
    height: 210px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .photo-item--contain img {
    object-fit: contain;
    background: rgba(255,255,255,0.04);
  }

  .photo-item:hover img {
    transform: scale(1.03);
  }

  .photo-item figcaption {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    font-family: var(--font-heading);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .photo-item {
      width: 220px;
    }

    .photo-item img {
      height: 165px;
    }

    .ribbon-track {
      animation-duration: 20s;
    }
  }
</style>
