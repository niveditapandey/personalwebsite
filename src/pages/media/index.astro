---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sections = [
  {
    title: "IIM — Startup Conclave",
    photos: [
      { src: "/media/IIM_PanelDiscussion.JPG", caption: "Panel discussion, IIM" },
      { src: "/media/IIM_StartupConclave-PanelDiscussion.jpeg", caption: "Startup Conclave panel, IIM" },
      { src: "/media/IIM_AwardPlaque.JPG", caption: "Felicitated as judge & guest speaker" },
    ]
  },
  {
    title: "SKIPA — Guest Lectures on AI for New Civil Servants",
    photos: [
      { src: "/media/SKIPA-Lecture_FistRaised_Feb26.jpg", caption: "AI lecture, February 2026" },
      { src: "/media/SKIPA-Lecture_HandRaised_Mar05.jpg", caption: "AI lecture, March 2026" },
      { src: "/media/SKIPA-Lecture_AudienceView_Mar05.jpg", caption: "Audience view, March 2026" },
      { src: "/media/SKIPA-Lecture_AIToolsInAction_Feb27.jpg", caption: "AI Tools in Action, February 2026", position: "top" },
      { src: "/media/SKIPA-Lecture_AlgorithmicBias_Feb24.jpg", caption: "Algorithmic Bias, February 2026" },
      { src: "/media/SKIPA-Lecture_GenAI-Slide_Feb27.jpg", caption: "GenAI lecture, February 2026" },
      { src: "/media/SKIPA-Lecture_PolicyToPrototype_Mar07.jpeg", caption: "Policy to Prototype, March 2026", position: "top" },
      { src: "/media/SKIPA-Lecture_AIGovernance-Jharkhand_Mar17.jpeg", caption: "AI Governance, Jharkhand, January 2026" },
      { src: "/media/SKIPA-Lecture_QRCode_Mar07.jpeg", caption: "Session resources, March 2026" },
    ]
  },
  {
    title: "SKIPA — Valedictory Ceremony",
    photos: [
      { src: "/media/SKIPA-Convocation_ValedictorySpeech.JPG", caption: "Valedictory speech" },
      { src: "/media/SKIPA-Convocation_CertificateHandover.JPG", caption: "Certificate handover" },
      { src: "/media/SKIPA-Convocation_LampLighting.JPG", caption: "Lamp lighting ceremony" },
      { src: "/media/SKIPA-Convocation_PlantGift.JPG", caption: "Guest felicitation" },
    ]
  },
];
---

<BaseLayout title="Media — Nivedita Pandey">
  <div class="media-page">
    <header class="page-header">
      <h1>Media</h1>
      <p class="page-description">
        Guest lectures, panels, and events.
      </p>
    </header>

    {sections.map((section) => (
      <section class="media-section">
        <h2 class="section-title">{section.title}</h2>
        <div class="photo-grid">
          {section.photos.map((p) => (
            <figure class="photo-item">
              <img src={p.src} alt={p.caption} loading="lazy" style={p.position ? `object-position: center ${p.position}` : undefined} />
              <figcaption>{p.caption}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .media-page {
    max-width: 1000px;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .media-section {
    margin-bottom: 5rem;
    padding-bottom: 5rem;
    border-bottom: 1px solid var(--border);
  }

  .media-section:last-child {
    border-bottom: none;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 1.75rem;
    font-family: var(--font-heading);
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .photo-item {
    margin: 0;
    overflow: hidden;
  }

  .photo-item img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .photo-item:hover img {
    transform: scale(1.03);
  }

  .photo-item figcaption {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    font-family: var(--font-heading);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .photo-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
