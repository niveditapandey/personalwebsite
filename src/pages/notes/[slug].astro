---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
---

<BaseLayout title={`${note.data.title} — Nivedita Pandey`}>
  <article class="note">
    <header class="note-header">
      <time datetime={note.data.publishDate.toISOString()}>
        {note.data.publishDate.toLocaleDateString('en-US', { 
          year: 'numeric', 
          month: 'long', 
          day: 'numeric' 
        })}
      </time>
      <h1>{note.data.title}</h1>
      {note.data.tags.length > 0 && (
        <div class="note-tags">
          {note.data.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    
    <div class="note-content">
      <Content />
    </div>
    
    <footer class="note-footer">
      <a href="/notes" class="back-link">← Back to notes</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .note {
    max-width: 650px;
  }
  
  .note-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  
  .note-header time {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  
  .note-header h1 {
    font-size: 2rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 1rem;
  }
  
  .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .tag {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: rgba(125, 166, 255, 0.1);
    color: var(--accent);
    border-radius: 3px;
  }
  
  .note-content {
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1.0625rem;
  }
  
  .note-content :global(p) {
    margin-bottom: 1.5rem;
  }
  
  .note-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }
  
  .note-content :global(em) {
    font-style: italic;
  }
  
  .note-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }
  
  .note-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  
  .back-link {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--text-muted);
  }
  
  .back-link:hover {
    color: var(--accent);
  }
  
  @media (max-width: 768px) {
    .note-header h1 {
      font-size: 1.75rem;
    }
  }
</style>
