---
import BaseLayout from '../layouts/BaseLayout.astro';

// object-position for the adventure photo banner — adjust if crop is off
const adventureCrop = "center";
---

<BaseLayout title="Beyond Work — Nivedita Pandey">
  <div class="beyond-page">
    <header class="page-header">
      <h1>Beyond Work</h1>
      <p class="page-description">
        Outside of professional work, I have several deep interests that shape how I think and live.
      </p>
    </header>

    <div class="beyond-grid">

      <div class="beyond-item">
        <h2>Spirituality</h2>
        <p>
          I maintain a serious engagement with Vedic astrology, the Ramcharitmanas, and meditation practices. These aren't
          casual interests—they're frameworks I use to understand purpose, time, and uncertainty.
        </p>
      </div>

      <div class="beyond-item">
        <h2>Animals & Rescue</h2>
        <p>
          I have a profound connection with animals, particularly cats. I support animal rescue work and believe in the
          responsibility we have toward creatures who cannot advocate for themselves.
        </p>
      </div>

      <div class="beyond-item">
        <h2>Adventure Sports</h2>
        <div class="section-banner">
          <img
            src="/images/beyond-adventure.png"
            alt="Rappelling"
            class="section-banner-img"
            style={`object-position: ${adventureCrop}`}
          />
        </div>
        <p>
          Skydiving, PADI-certified diving, ziplining, rappelling, and more. There's something about putting yourself
          in situations that require full presence — no multitasking, no distraction — that I find clarifying.
        </p>
      </div>

      <div class="beyond-item">
        <h2>Travel & Languages</h2>
        <p>
          Travelled to 16+ countries across Asia, Europe, and the Americas. Living and working across four countries
          has made me fluent in reading context — how systems, cultures, and institutions operate differently
          depending on where you are. Travel is less about tourism and more about pattern recognition.
        </p>
        <p>
          I speak English and Hindi, and have learnt both French and Sanskrit — two languages as different from
          each other as they could be, and both endlessly rewarding.
        </p>
      </div>

      <div class="beyond-item">
        <h2>Performing Arts</h2>
        <p>
          Learning piano. Singing. More to be added here.
        </p>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .beyond-page {
    max-width: 750px;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .beyond-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .beyond-item {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .beyond-item:last-child {
    border-bottom: none;
  }

  .beyond-item h2 {
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 1rem;
    color: var(--text-primary);
    font-family: var(--font-heading);
  }

  .beyond-item p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 0;
  }

  .beyond-item p + p {
    margin-top: 1rem;
  }

  .section-banner {
    width: 100%;
    height: 280px;
    overflow: hidden;
    margin-bottom: 1.25rem;
  }

  .section-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .section-banner {
      height: 200px;
    }
  }
</style>
