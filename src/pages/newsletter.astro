---
import BaseLayout from '../layouts/BaseLayout.astro';

// object-position for the newsletter photo banner — adjust if crop is off
const photoCrop = "center";
---

<BaseLayout title="Newsletter — Nivedita Pandey">
  <div class="newsletter-page">
    <header class="page-header">
      <h1>Newsletter</h1>
      <p class="page-description">
        Irregular dispatches on applied AI, digital public infrastructure, institutional change,
        and the systems that shape how we work and live.
      </p>
    </header>

    <div class="page-banner">
      <img
        src="/images/about-bio.png"
        alt="Nivedita Pandey"
        class="page-banner-img"
        style={`object-position: ${photoCrop}`}
      />
    </div>

    <section class="subscribe-section">
      <h2>Subscribe</h2>
      <p>
        To receive new issues, send an email expressing your interest and I'll add you to the list.
        No forms, no automation — just a direct line.
      </p>
      <a
        href="mailto:np@niveditapandey.com?subject=Newsletter%20subscription"
        class="subscribe-cta"
      >
        np@niveditapandey.com →
      </a>
    </section>

    <section class="about-section">
      <h2>What to expect</h2>
      <p>
        The newsletter is a space for thinking out loud — on problems I'm working through,
        patterns I'm noticing, and ideas that don't fit neatly into an article.
        Topics include applied AI, go-to-market strategy, digital public infrastructure,
        and cross-border ecosystem building.
      </p>
      <p>
        Sent when there's something worth saying. Not on a fixed schedule.
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .newsletter-page {
    max-width: 700px;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .page-banner {
    width: 100%;
    height: 300px;
    overflow: hidden;
    margin-bottom: 3rem;
  }

  .page-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .subscribe-section,
  .about-section {
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--border);
  }

  .about-section {
    border-bottom: none;
  }

  .subscribe-section h2,
  .about-section h2 {
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 1rem;
    font-family: var(--font-heading);
  }

  .subscribe-section p,
  .about-section p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .about-section p:last-child {
    margin-bottom: 0;
  }

  .subscribe-cta {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 1.125rem;
    color: var(--accent);
    transition: color 0.2s ease;
  }

  .subscribe-cta:hover {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .page-banner {
      height: 220px;
    }
  }
</style>
