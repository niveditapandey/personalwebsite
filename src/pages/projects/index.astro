---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => (a.data.year || 0) - (b.data.year || 0));

const sectors = ['Private Sector', 'Startup', 'Public Sector'];

const sectorColors: Record<string, string> = {
  'Private Sector': '#60a5fa',
  'Startup': '#a78bfa',
  'Public Sector': '#34d399',
};
---

<BaseLayout title="Past Work — Nivedita Pandey">
  <div class="projects-page">
    <header class="page-header">
      <h1>Work Snapshots</h1>
      <p class="page-description">
        A selective look at challenges tackled across 16 years — in private enterprise, startups, and public institutions.
        What the problem was, what was delivered. Not the how — that's the conversation.
      </p>
    </header>

    {sectors.map((sector) => {
      const projects = allProjects.filter(p => p.data.industry === sector);
      if (projects.length === 0) return null;
      const color = sectorColors[sector];
      return (
        <section class="sector-section">
          <h2 class="sector-heading" style={`--sector-color: ${color}`}>{sector}</h2>
          <div class="cards-grid">
            {projects.map((project) => (
              <div class="project-card" style={`--card-accent: ${color}`}>
                <div class="card-top">
                  <span class="card-year">{project.data.year}</span>
                  <span class="card-sector-badge" style={`color: ${color}; border-color: ${color}30`}>{project.data.industry}</span>
                </div>
                <h3 class="card-title">{project.data.title}</h3>
                {project.data.context && (
                  <p class="card-context">{project.data.context}</p>
                )}
                <div class="card-rows">
                  <div class="card-row">
                    <span class="row-label">Challenge</span>
                    <span class="row-value">{project.data.problem}</span>
                  </div>
                  <div class="card-row">
                    <span class="row-label">Outcome</span>
                    <span class="row-value row-value--impact">{project.data.impact}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      );
    })}

    <p class="page-footer">
      Interested in working together?
      <a href="mailto:nivedita@dendrons.ai">nivedita@dendrons.ai</a>
    </p>
  </div>
</BaseLayout>

<style>
  .projects-page {
    max-width: 960px;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .page-description {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.75;
    max-width: 680px;
  }

  .sector-section {
    margin-bottom: 4rem;
  }

  .sector-heading {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--sector-color, var(--text-muted));
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .cards-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .project-card {
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-left: 3px solid var(--card-accent, rgba(255,255,255,0.2));
    padding: 2rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.3), 0 1px 4px rgba(0, 0, 0, 0.2);
    transition: box-shadow 0.2s ease, background 0.2s ease;
  }

  .project-card:hover {
    background: rgba(255, 255, 255, 0.065);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4), 0 2px 8px rgba(0, 0, 0, 0.25);
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .card-year {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .card-sector-badge {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.6rem;
    border: 1px solid;
    border-radius: 2px;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.35;
    margin: 0;
  }

  .card-context {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .card-rows {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .card-row {
    display: grid;
    grid-template-columns: 82px 1fr;
    gap: 1rem;
    align-items: baseline;
  }

  .row-label {
    font-family: var(--font-heading);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--text-muted);
    padding-top: 0.15rem;
  }

  .row-value {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .row-value--impact {
    color: var(--text-primary);
    font-weight: 500;
  }

  .page-footer {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-top: 1rem;
    padding-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .page-footer a {
    color: var(--accent);
    font-family: var(--font-heading);
    margin-left: 0.25rem;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }

    .project-card {
      padding: 1.5rem;
    }
  }
</style>
