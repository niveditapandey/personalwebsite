---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => (b.data.order || 0) - (a.data.order || 0));

const sectors = ['Private Sector', 'Startup', 'Public Sector'];

const projectTags: Record<string, string[]> = {
  'male-grooming-us-asia':        ['strategy', 'growth', 'new launch'],
  'digital-gold-india':           ['strategy', 'new launch', 'growth'],
  'microsoft-pe-partnerships':    ['strategy', 'growth', 'new launch'],
  'india-g2c-payments':           ['strategy', 'new launch'],
  'ai-governance-financial':      ['strategy', 'CEO advisory'],
  'enterprise-tech-acceleration': ['acceleration', 'CEO advisory'],
  'healthcare-coordination':      ['strategy', 'new launch'],
};
---

<BaseLayout title="Past Work — Nivedita Pandey">
  <div class="projects-page">
    <header class="page-header">
      <h1>Work Snapshots</h1>
      <p class="page-description">
        Snapshots of challenges tackled across employment and consulting engagements —
        private sector, startups, and public institutions. Not exhaustive, but representative.
      </p>
    </header>

    {sectors.map((sector) => {
      const projects = allProjects.filter(p => p.data.industry === sector);
      if (projects.length === 0) return null;
      return (
        <section class="sector-section" id={sector.toLowerCase().replace(' ', '-')}>
          <h2 class="sector-heading">{sector}</h2>
          <div class="projects-list">
            {projects.map((project) => (
              <a href={`/projects/${project.slug}`} class="project-card">
                <div class="project-meta">
                  <span class="project-year">{project.data.year}</span>
                  {(projectTags[project.slug] || []).map(tag => (
                    <span class="project-tag">{tag}</span>
                  ))}
                </div>
                <h3 class="project-title">{project.data.title}</h3>
                <p class="project-problem">{project.data.problem}</p>
                <span class="project-link">View project →</span>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>

<style>
  .projects-page {
    max-width: 900px;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .sector-section {
    margin-bottom: 4rem;
  }

  .sector-heading {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-family: var(--font-heading);
    font-weight: 500;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .projects-list {
    display: flex;
    flex-direction: column;
  }

  .project-card {
    display: block;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    transition: border-color 0.2s ease;
  }

  .project-card:last-child {
    border-bottom: none;
  }

  .project-card:hover {
    border-color: var(--accent);
  }

  .project-card:hover .project-link {
    color: var(--accent);
  }

  .project-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
    flex-wrap: wrap;
  }

  .project-year {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .project-tag {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--accent);
    border: 1px solid rgba(96, 165, 250, 0.3);
    padding: 0.15rem 0.6rem;
    border-radius: 2px;
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }

  .project-title {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
    font-weight: 500;
    line-height: 1.3;
  }

  .project-problem {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .project-link {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2rem;
    }
  }
</style>
